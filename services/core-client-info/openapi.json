  "components": {
    "schemas": {
      "AcademicInfoItem": {
        "properties": {
          "label": {
            "type": "string",
            "title": "Label"
          },
          "value": {
            "type": "string",
            "title": "Value"
          }
        },
        "type": "object",
        "required": ["label", "value"],
        "title": "AcademicInfoItem"
      },
      "BatchUsersRequest": {
        "properties": {
          "user_ids": {
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "type": "array",
            "maxItems": 100,
            "title": "User Ids"
          }
        },
        "type": "object",
        "required": ["user_ids"],
        "title": "BatchUsersRequest"
      },
      "ChangeEmailRequest": {
        "properties": {
          "new_email": {
            "type": "string",
            "title": "New Email"
          },
          "challenge_id": {
            "type": "string",
            "format": "uuid",
            "title": "Challenge Id"
          }
        },
        "type": "object",
        "required": ["new_email", "challenge_id"],
        "title": "ChangeEmailRequest"
      },
      "ChangePasswordRequest": {
        "properties": {
          "new_password": {
            "type": "string",
            "title": "New Password"
          },
          "challenge_id": {
            "type": "string",
            "format": "uuid",
            "title": "Challenge Id"
          }
        },
        "type": "object",
        "required": ["new_password", "challenge_id"],
        "title": "ChangePasswordRequest"
      },
      "GradeImprovementResponse": {
        "properties": {
          "subject": {
            "type": "string",
            "title": "Subject"
          },
          "old_grade": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Old Grade"
          },
          "new_grade": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "New Grade"
          },
          "improvement": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Improvement"
          },
          "grade_date": {
            "type": "string",
            "format": "date-time",
            "title": "Grade Date"
          }
        },
        "type": "object",
        "required": ["subject", "old_grade", "new_grade", "improvement", "grade_date"],
        "title": "GradeImprovementResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "InitUserRequest": {
        "properties": {
          "user_id": {
            "type": "string",
            "format": "uuid",
            "title": "User Id"
          }
        },
        "type": "object",
        "required": ["user_id"],
        "title": "InitUserRequest"
      },
      "MessageResponse": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": ["message"],
        "title": "MessageResponse"
      },
      "PersonalDataResponse": {
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserResponse"
          },
