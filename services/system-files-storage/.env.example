# Server Configuration
PORT=8007
PYTHON_ENV=development
# Loki (Optional for local development)
LOKI_ENDPOINT=http://localhost:3100/otlp/v1/logs

# JWT Configuration
JWT_SECRET=local-development-secret

# S3 / MinIO Configuration
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=messages-attachments
S3_REGION=us-east-1

# Service URLs
CORE_MESSAGES_URL=http://localhost:8006/core-messages
CORE_AUTH_URL=http://localhost:8002/core-auth
