{
  "include": ["services/core-applications/app", "services/core-client-info/app", "infra/checks"],
  "exclude": ["**/node_modules", "**/__pycache__", "**/.venv", "**/alembic/versions"],
  "ignore": ["**/node_modules", "**/.venv"],
  "defineConstant": {
    "DEBUG": true
  },
  "stubPath": "",
  "reportMissingImports": "warning",
  "reportMissingTypeStubs": false,
  "pythonVersion": "3.12",
  "pythonPlatform": "Darwin",
  "executionEnvironments": [
    {
      "root": "services/core-applications",
      "pythonVersion": "3.12",
      "pythonPlatform": "Darwin",
      "extraPaths": ["services/core-applications"]
    },
    {
      "root": "services/core-client-info",
      "pythonVersion": "3.12",
      "pythonPlatform": "Darwin",
      "extraPaths": ["services/core-client-info"]
    }
  ]
}
