import { Module } from '@nestjs/common';
import { ConfigModule } from '@nestjs/config';
import { APP_INTERCEPTOR } from '@nestjs/core';
import {
  {{#if hasDatabase}}createDatabaseImports,{{/if}}
  HealthModule,
  LoggerModule,
  SESSION_CHECK_ROUTES,
  SessionCheckInterceptor,
} from '@supreme-int/nestjs-shared';
import { authRoutes } from '../_auth-routes.generated';

@Module({
  imports: [
    ConfigModule.forRoot({ isGlobal: true }),
    LoggerModule,
    HealthModule.forRoot({ serviceName: '{{serviceName}}' }),{{#if hasDatabase}}
    ...createDatabaseImports(),{{/if}}
  ],
  controllers: [],
  providers: [
    {
      provide: SESSION_CHECK_ROUTES,
      useValue: authRoutes,
    },
    {
      provide: APP_INTERCEPTOR,
      useClass: SessionCheckInterceptor,
    },
  ],
})
export class AppModule {}

